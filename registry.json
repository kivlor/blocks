        "@tanstack/react-table",
        "lucide-react"
      ],
      "registryDependencies": [
        "button",
        "dropdown-menu",
        "input",
        "select",
        "table"
      ],
      "files": [
        {
          "path": "components/ui/data-table.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "dialog-form",
      "type": "registry:ui",
