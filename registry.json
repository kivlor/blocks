{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "blocks",
  "homepage": "https://blocks.kivlor.com",
  "items": [
    {
      "name": "confirm-action",
      "type": "registry:ui",
      "title": "Confirm Action",
      "description": "A confirmation dialog that can require typed confirmation before running an action.",
      "dependencies": [
        "lucide-react"
      ],
      "registryDependencies": [
        "alert-dialog",
        "button",
        "input"
      ],
      "files": [
        {
          "path": "components/ui/confirm-action.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "data-table",
      "type": "registry:ui",
      "title": "Data Table",
      "description": "A reusable TanStack table with search, filtering, pagination, sorting state, and row actions.",
