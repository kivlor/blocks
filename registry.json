      "description": "A reusable dialog shell for forms with scrollable content.",
      "registryDependencies": [
        "dialog"
      ],
      "files": [
        {
          "path": "components/ui/dialog-form.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "sheet-form",
      "type": "registry:ui",
