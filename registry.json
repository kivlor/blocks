      "description": "A submit button that disables itself and shows a spinner while pending.",
      "dependencies": [
        "lucide-react"
      ],
      "registryDependencies": [
        "button"
      ],
      "files": [
        {
          "path": "components/ui/submit-button.tsx",
          "type": "registry:ui"
        }
